#!/usr/bin/env python3
"""Audit stack/skill default bundles and intent-triggered optional skills."""

from __future__ import annotations

import json
import subprocess
import tempfile
from pathlib import Path

import yaml


ROOT = Path(__file__).resolve().parents[1]

EXPECTED_DEFAULTS = {
    "rails-web": {
        "rds-context7-mount",
        "rds-mockup-fidelity",
        "rds-secrets-broker",
        "rds-eval-harness",

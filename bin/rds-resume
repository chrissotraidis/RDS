#!/usr/bin/env bash
# bin/rds-resume — restart a failed/incomplete build from where it broke.
#
# Reads builds/<id>/state.json to reconstruct the original rds-build invocation
# (mode, app_dest, repo_url/prd or trigger, stack, deploy_target if recorded),
# then spawns rds-build with --resume --build-id=<id>. The resumed build skips
# stages already marked done|skipped and re-runs the failed/running stage.
#
# Usage:
#   bin/rds-resume <build-id>           # foreground; logs to stdout
#   bin/rds-resume <build-id> --detach  # background; logs to /dev/shm/<id>-launch-build.log + builds/<id>/logs/resume.log
#
# Exit codes: 0 on launch (or build success in foreground), non-zero otherwise.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/bin/lib/common.sh"

BUILD_ID="${1:-}"
shift || true
[[ -n "$BUILD_ID" ]] || { echo "usage: bin/rds-resume <build-id> [--detach]" >&2; exit 1; }

DETACH=0
for arg in "$@"; do
  case "$arg" in
    --detach) DETACH=1 ;;
    -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
    *) echo "unknown arg: $arg" >&2; exit 1 ;;
  esac
done

BUILD_DIR="$RDS_BUILDS_DIR/$BUILD_ID"
STATE="$BUILD_DIR/state.json"
[[ -f "$STATE" ]] || { echo "no such build: $STATE" >&2; exit 1; }

mode="$(jq -r '.mode // "green"' "$STATE")"
stack="$(jq -r '.stack // "rails"' "$STATE")"
app_dest="$(jq -r '.app_dest // empty' "$STATE")"
trigger="$(jq -r '.trigger // empty' "$STATE")"
repo_url="$(jq -r '.repo_url // empty' "$STATE")"
prd_source="$(jq -r '.prd_source // empty' "$STATE")"
provider="$(jq -r '.inference.provider // empty' "$STATE")"
claude_model="$(jq -r '.inference.claude_model // empty' "$STATE")"
codex_model="$(jq -r '.inference.codex_model // empty' "$STATE")"
app_type="$(jq -r '.app_type // "auto"' "$STATE")"
deploy_target="${RDS_DEFAULT_DEPLOY_TARGET:-zo}"

[[ -n "$app_dest" ]] || { echo "FATAL: state.json has no app_dest — cannot resume" >&2; exit 1; }

args=(--resume --build-id="$BUILD_ID" --app-dest="$app_dest" --stack="$stack" --deploy-target="$deploy_target")
[[ -n "$provider" ]] && args+=(--provider="$provider")
[[ -n "$claude_model" ]] && args+=(--claude-model="$claude_model")
[[ -n "$codex_model" ]] && args+=(--codex-model="$codex_model")
[[ -n "$app_type" && "$app_type" != "null" ]] && args+=(--app-type="$app_type")

if [[ "$mode" == "brown" ]]; then
  [[ -n "$repo_url" && -n "$prd_source" ]] || {
    echo "FATAL: brown-field resume requires repo_url + prd_source in state.json" >&2; exit 1;
  }
  args+=(--repo="$repo_url" --prd="$prd_source")
else
  [[ -n "$trigger" ]] || {
    echo "FATAL: green-field resume requires trigger in state.json" >&2; exit 1;
  }
  # Trigger is a positional arg; rds-build takes the first non-flag positional.
  args+=("$trigger")
fi

SHM_LOG="/dev/shm/${BUILD_ID}-launch-build.log"
RESUME_LOG="$BUILD_DIR/logs/resume.log"
PIDFILE="$BUILD_DIR/run.pid"
echo "[rds-resume] resuming $BUILD_ID (mode=$mode stack=$stack app_dest=$app_dest)"
echo "[rds-resume] command: bin/rds-build ${args[*]}"

if (( DETACH == 1 )); then
  mkdir -p "$BUILD_DIR/logs"
  : >> "$SHM_LOG"
  : >> "$RESUME_LOG"
  setsid nohup bash -c '
    shm_log="$1"; resume_log="$2"; build="$3"; shift 3
    "$build" "$@" 2>&1 | tee -a "$shm_log" >> "$resume_log"
  ' rds-resume "$SHM_LOG" "$RESUME_LOG" "$ROOT/bin/rds-build" "${args[@]}" </dev/null >/dev/null 2>&1 &
  child=$!
  {
    printf 'pid=%s\n'        "$child"
    printf 'pgid=%s\n'       "$child"
    printf 'build_id=%s\n'   "$BUILD_ID"
    printf 'mode=%s\n'       "$mode"
    printf 'resumed_at=%s\n' "$(date -u +%FT%TZ)"
    printf 'host=%s\n'       "$(hostname)"
    printf 'log=%s\n'        "$SHM_LOG"
    printf 'archive=%s\n'    "$RESUME_LOG"
  } > "$PIDFILE.tmp"
  mv "$PIDFILE.tmp" "$PIDFILE"
  echo "[rds-resume] detached pid=$child log=$SHM_LOG archive=$RESUME_LOG pidfile=$PIDFILE"
  exit 0
fi

exec "$ROOT/bin/rds-build" "${args[@]}"

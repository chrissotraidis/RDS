#!/usr/bin/env python3
"""Run a Zo visual/design review over the latest RDS QA screenshots."""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any

MODEL_NAME = "byok:a48f26a1-6765-4644-8d36-68ef5a9a51ad"

# Substrings that indicate the LLM call failed for infrastructure reasons
# (quota, rate-limit, auth), not because the design is actually bad. When any
# of these appear in the model output, write status=skipped with explicit
# reviewerError evidence. Downstream taste/readiness treats skipped as missing
# design evidence, not as a pass.
INFRA_ERROR_PATTERNS = re.compile(
    r"\b("
    r"usage limit|"
    r"rate limit(?:ed|ing)?|"
    r"quota (?:exceeded|reached|hit)|"
    r"too many requests|"
    r"insufficient quota|"
    r"upgrade your plan|"
    r"billing|"
    r"unauthorized|"
    r"invalid api key|"
    r"capacity"
    r")\b",
    re.I,
)


def looks_like_infra_error(text: str) -> bool:
    return bool(text) and bool(INFRA_ERROR_PATTERNS.search(text))


def write_skipped(out_path: Path, screenshots: list[str], reason: str, evidence: str = "") -> None:
    payload = {
        "schema": "rds.qa.design-review.v1",
        "status": "skipped",
        "score": None,
        "summary": f"Design review skipped: {reason}",
        "issues": [],
        "reviewerError": {
            "kind": reason,
            "evidence": evidence[:1000],
        },
        "screenshotsReviewed": screenshots[:10],
    }
    out_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def read_text(path: Path, limit: int = 120_000) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="replace")[:limit]
    except Exception:
        return ""


def read_json(path: Path) -> Any:
    try:
        return json.loads(read_text(path))
    except Exception:
        return None


def extract_json(text: str) -> dict[str, Any]:
    text = text.strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*", "", text)
        text = re.sub(r"\s*```$", "", text)
    try:
        value = json.loads(text)
        return value if isinstance(value, dict) else {}
    except Exception:
        pass
    match = re.search(r"\{.*\}", text, flags=re.S)
    if not match:
        return {}
    value = json.loads(match.group(0))
    return value if isinstance(value, dict) else {}


def latest_iter(build_dir: Path) -> Path | None:
    root = build_dir / "playwright"
    if not root.exists():
        return None
    iters = sorted(p for p in root.glob("iter-*") if p.is_dir())
    return iters[-1] if iters else None


def normalized_status(value: Any) -> str:
    status = str(value or "").strip().lower().replace("-", "_")
    if status in {"pass", "passed"}:
        return "pass"
    if status in {"fail", "failed"}:
        return "fail"
    return "needs_iteration"


def identity_token() -> str:
    token = os.environ.get("ZO_CLIENT_IDENTITY_TOKEN", "")
    if token:
        return token
    secrets = Path("/root/.zo_secrets")
    if not secrets.exists():
        return ""
    try:
        return subprocess.check_output(
            ["bash", "-lc", "source /root/.zo_secrets >/dev/null 2>&1 && printf '%s' \"$ZO_CLIENT_IDENTITY_TOKEN\""],
            text=True,
            timeout=5,
        ).strip()
    except Exception:
        return ""


def refresh_identity_token() -> str:
    secrets = Path("/root/.zo_secrets")
    if not secrets.exists():
        return ""
    try:
        return subprocess.check_output(
            ["bash", "-lc", "source /root/.zo_secrets >/dev/null 2>&1 && printf '%s' \"$ZO_CLIENT_IDENTITY_TOKEN\""],
            text=True,
            timeout=5,
        ).strip()
    except Exception:
        return ""


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("build_id")
    parser.add_argument("--root", default=str(Path(__file__).resolve().parents[1]))
    parser.add_argument("--iteration-dir", default="")
    args = parser.parse_args()

    root = Path(args.root).resolve()
    build_dir = root / "builds" / args.build_id
    if not build_dir.exists():
        raise SystemExit(f"FATAL: build not found: {build_dir}")

    iter_dir = Path(args.iteration_dir).resolve() if args.iteration_dir else latest_iter(build_dir)
    if not iter_dir or not iter_dir.exists():
        raise SystemExit("FATAL: no Playwright iteration found")

    token = identity_token()
    out_path = iter_dir / "design-review.json"
    if not token:
        out_path.write_text(json.dumps({
            "schema": "rds.qa.design-review.v1",
            "status": "skipped",
            "reason": "ZO_CLIENT_IDENTITY_TOKEN not available",
        }, indent=2) + "\n", encoding="utf-8")
        print(json.dumps({"status": "skipped", "path": str(out_path)}))
        return 0

    screenshots = sorted(str(p) for p in iter_dir.glob("*.png"))
    summary = read_json(iter_dir / "summary.json") or {}
    game = read_json(iter_dir / "game-verdict.json") or {}
    visual = read_json(iter_dir / "visual-verdict.json") or {}
    state = read_json(build_dir / "state.json") or {}
    spec_excerpt = read_text(build_dir / "spec.md", 18_000)

    prompt = f"""
You are the RDS design-quality gate. Inspect the actual screenshots using your image tools before judging.

Build: {args.build_id}
App type: {state.get("app_type")}
Preview URL: {state.get("preview_url")}

Screenshots to inspect:
{chr(10).join(f"- {path}" for path in screenshots[:10])}

Existing machine QA:
summary.json:
```json
{json.dumps(summary, indent=2)[:12000]}
```

game-verdict.json:
```json
{json.dumps(game, indent=2)[:8000]}
```

visual-verdict.json:
```json
{json.dumps(visual, indent=2)[:8000]}
```

Spec excerpt:
```markdown
{spec_excerpt}
```

Review standard:
- Fail broken or no-op links/buttons, even if machine QA missed them.
- Fail visibly misaligned, cramped, clipped, overlapping, or non-responsive UI.
- For games, fail if the screenshots do not show a compelling playable surface, readable HUD, clear controls, and evidence of actual play/progression.
- Fail generic/debug UI, visible health/debug links, placeholder-feeling layouts, or apps that look materially worse than a quick human prototype.
- Be strict. Passing means "reasonable to show for operator review", not "no runtime exception".

Return ONLY JSON with this exact shape:
{{
  "schema": "rds.qa.design-review.v1",
  "status": "pass|needs_iteration|fail",
  "score": 0-100,
  "summary": "one sentence",
  "issues": [
    {{"severity":"blocker|major|minor","kind":"broken_control|misalignment|responsive|gameplay|visual_design|debug_artifact|other","evidence":"specific screenshot/element evidence","fixHint":"specific fix"}}
  ],
  "screenshotsReviewed": ["paths you inspected"]
}}
"""

    def ask(current_token: str) -> dict[str, Any]:
        req = urllib.request.Request(
            "https://api.zo.computer/zo/ask",
            data=json.dumps({"input": prompt, "model_name": MODEL_NAME}).encode("utf-8"),
            headers={
                "authorization": current_token,
                "content-type": "application/json",
                "accept": "application/json",
            },
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=240) as resp:
            return json.loads(resp.read().decode("utf-8", errors="replace"))

    # Infrastructure errors (quota, rate-limit, auth) should not be encoded as
    # design failures. Retry once for 429 with backoff; for everything non-2xx
    # other than 401, write status=skipped and return 0 so the build can keep
    # moving into taste/readiness, where skipped design evidence blocks review.
    try:
        payload = ask(token)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")[:1200]
        if exc.code == 401:
            fresh = refresh_identity_token()
            if fresh and fresh != token:
                try:
                    payload = ask(fresh)
                except urllib.error.HTTPError as retry_exc:
                    body2 = retry_exc.read().decode("utf-8", errors="replace")[:1200]
                    write_skipped(out_path, screenshots, f"http_{retry_exc.code}", body2)
                    print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": f"http_{retry_exc.code}"}))
                    return 0
            else:
                write_skipped(out_path, screenshots, "http_401", body)
                print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": "http_401"}))
                return 0
        elif exc.code == 429:
            time.sleep(30)
            try:
                payload = ask(token)
            except urllib.error.HTTPError as retry_exc:
                body2 = retry_exc.read().decode("utf-8", errors="replace")[:1200]
                write_skipped(out_path, screenshots, f"http_{retry_exc.code}_after_retry", body2)
                print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": f"http_{retry_exc.code}"}))
                return 0
        else:
            write_skipped(out_path, screenshots, f"http_{exc.code}", body)
            print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": f"http_{exc.code}"}))
            return 0
    except urllib.error.URLError as exc:
        write_skipped(out_path, screenshots, "url_error", str(exc))
        print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": "url_error"}))
        return 0

    output = payload.get("output", "")
    if isinstance(output, dict):
        review = output
    else:
        review = extract_json(str(output))

    # Infra error masquerading as model output (quota/limit text in the body).
    raw_output_str = output if isinstance(output, str) else json.dumps(output)
    review_text = json.dumps(review) if review else raw_output_str
    if looks_like_infra_error(review_text) or looks_like_infra_error(raw_output_str):
        write_skipped(out_path, screenshots, "model_quota_or_limit", raw_output_str[:1000])
        print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": "model_quota_or_limit"}))
        return 0

    if not review:
        write_skipped(out_path, screenshots, "unparsable_output", raw_output_str[:1000])
        print(json.dumps({"status": "skipped", "path": str(out_path), "reviewer_error": "unparsable_output"}))
        return 0

    review["schema"] = "rds.qa.design-review.v1"
    review["status"] = normalized_status(review.get("status"))
    review.setdefault("screenshotsReviewed", screenshots[:10])
    out_path.write_text(json.dumps(review, indent=2) + "\n", encoding="utf-8")
    print(json.dumps({"status": review["status"], "score": review.get("score"), "path": str(out_path)}))
    return 0 if review["status"] == "pass" else 1


if __name__ == "__main__":
    raise SystemExit(main())

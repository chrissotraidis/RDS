# Default values sourced by bin/ scripts. These can be overridden in .env.
# bin/lib/common.sh sources config/defaults.env first, then .env, so .env wins.

RDS_DEFAULT_DEPLOY_TARGET=zo
RDS_DEFAULT_DB=postgres

# Stage timeouts (seconds)
RDS_WAIT_HEALTH_TIMEOUT_SEC=120
RDS_WIKI_TIMEOUT_SEC=900
RDS_SCAFFOLD_TIMEOUT_SEC=7200
RDS_QA_REQUIRED=1
RDS_QA_MAX_PAGES=40
RDS_QA_DEPTH=3

# Taste layer
RDS_TASTE_ENABLED=1
RDS_TASTE_REQUIRED=1
RDS_TASTE_AUTO_ITERATE=1
RDS_SKIP_TASTE_REVIEW=0

# Local port range for RDS app previews. V1 standardizes on Zo-public
# preview ports across stacks.
RDS_LOCAL_PORT_RANGE_START=4000
RDS_LOCAL_PORT_RANGE_END=4099

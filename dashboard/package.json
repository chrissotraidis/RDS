{
  "name": "rds-dashboard",
  "version": "0.1.0",
  "description": "Persistent build dashboard for RDS.",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --hot src/server.ts",
    "selftest": "bun run tests/selftest.ts",
    "build:css": "tailwindcss -c tailwind.config.js -i src/tailwind.css -o public/tailwind.css --minify"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "bun-types": "^1.3.13",
    "playwright": "^1.48.0",
    "tailwindcss": "^3.4"
  }
}

# RDS local config — copy to .env and fill in.
# Every variable here is read by bin/ scripts or bootstrap/install.sh.

# --- Paths ---
RDS_HOME=/absolute/path/to/rds
RDS_BUILDS_DIR=/absolute/path/to/rds/builds
RDS_INBOX_DIR=/absolute/path/to/rds/inbox
RDS_EVENTS_PATH=/absolute/path/to/rds/events.jsonl
RDS_DASHBOARD_CHAT_DIR=/absolute/path/to/rds/dashboard/chat
RDS_DASHBOARD_STATE_DIR=/absolute/path/to/rds/dashboard

# For production-like installs, point mutable state at a separate data root:
# RDS_BUILDS_DIR=/var/lib/rds/builds
# RDS_INBOX_DIR=/var/lib/rds/inbox
# RDS_EVENTS_PATH=/var/lib/rds/events.jsonl
# RDS_DASHBOARD_CHAT_DIR=/var/lib/rds/dashboard-chat
# RDS_DASHBOARD_STATE_DIR=/var/lib/rds/dashboard-state

# --- Dashboard auth ---
# RDS implements its own Basic Auth gate for the dashboard. With no
# credentials set, the dashboard runs in setup mode: it serves direct
# localhost requests only (with a banner) and returns 503 to everything
# else. Set both values to secure the console and enable remote access.
RDS_DASHBOARD_USER=rds
RDS_DASHBOARD_PASSWORD=
RDS_DASHBOARD_TOKEN=

# --- Notion ---
# Notion MCP is expected to be configured at the Zo level, not via env.
# If you need a Notion integration token for direct API calls (fallback
# only; MCP is preferred), set it here.
# NOTION_INTEGRATION_TOKEN=

# --- Public hosting on Zo ---
ZO_PUBLIC_PORT_RANGE_START=4000
ZO_PUBLIC_PORT_RANGE_END=4099
# Zo owner/handle used for generated *.zocomputer.io preview URLs.
# Example: RDS_ZO_OWNER=your-handle
RDS_ZO_OWNER=
# Fill in after first install if your runtime needs an explicit host.
ZO_PUBLIC_HOST=

# --- Code-generation model ---
# Pinned in vendor/scaffold/templates/launch-build.sh; override here
# only when intentionally A/B testing build quality. Quietly downgrading
# the code-generation model usually looks like flaky implementation work,
# not like an obvious model/config error.
# RDS_CLAUDE_MODEL=claude-opus-4-8

# --- Telegram completion notifications (optional) ---
# Without these, builds finish silently and the operator checks status manually.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Defaults ---
RDS_DEFAULT_DB=postgres
RDS_DEFAULT_RUBY=3.3.5
